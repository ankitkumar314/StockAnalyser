# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# LangSmith Configuration (Optional - for tracing and monitoring)
# Get your API key from: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=rag-agent-system
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# PostgreSQL Database Configuration (Optional - for data persistence)
# Format: postgresql://username:password@host:port/database
# Example: postgresql://stockuser:password123@localhost:5432/stockanalyser
DATABASE_URL=postgresql://user:password@localhost:5432/stockanalyser
# Application Settings
# Add other environment variables as needed
